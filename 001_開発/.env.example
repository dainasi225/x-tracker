# Database (SQLite)
DATABASE_URL="file:./dev.db"

# Next.js
NODE_ENV="development"

# X API v2
# このアプリの現機能（ユーザー情報取得・履歴取得）では Bearer Token だけで動作
# ※ 投稿・フォローなど「ユーザーとして実行する機能」を将来追加する場合は OAuth 2.0 User Context が必要
# 取得方法: https://developer.twitter.com/en/portal/dashboard
# 従量課金: ユーザー情報取得は 1リクエスト約 $0.003 (24hキャッシュで費用を最小化)
X_API_BEARER_TOKEN=""
# 任意: 自分情報の同期時に使うデフォルトユーザー名（@なし）
X_MY_USERNAME=""


# 通知連携（任意）
# LINE Notify トークン: https://notify-bot.line.me/ja/
LINE_NOTIFY_TOKEN=""

# Discord Webhook URL
DISCORD_WEBHOOK_URL=""
